# Local testnet defaults. Copy this file to .env before deployment.
ADS_REF=v1.1.5
IMAGE_TAG=v1.1.5
NODE_ID=0001
INIT_NODE=true

# Bind to localhost by default. Use 0.0.0.0 only when you intend to expose a port.
P2P_BIND=127.0.0.1
P2P_HOST_PORT=8091
OFFICE_BIND=127.0.0.1
OFFICE_HOST_PORT=9091

CPU_LIMIT=2.0
MEMORY_LIMIT=4g
WATCH_INTERVAL=30
