# Adshares Mainnet Environment Configuration
# Copy this file to .env and fill in your actual values before deploying

# ============================================
# REQUIRED: Your mainnet node credentials
# ============================================

# Your 4-hex character node ID (e.g., A1B2, 0001)
# Must be registered in the Adshares network genesis block
NODE_ID=YOUR_NODE_ID_HERE

# Your 64-hex character node secret key
# Generate with: ./key "your-brain-key-string" (from adshares/ads/external/ed25519/)
# Or provided by Adshares team when assigning node ID
NODE_SECRET=YOUR_64_HEX_SECRET_HERE

# ============================================
# NETWORK: Your VPS public IP address
# ============================================

# Must be a publicly reachable IPv4 address
# Other Adshares nodes will use this to connect to your node
PUBLIC_IP=YOUR_VPS_PUBLIC_IP_HERE

# ============================================
# PORTS: Mainnet default ports
# ============================================

# P2P port (node-to-node communication)
P2P_PORT=6510

# Office port (client/API connections)
OFFICE_PORT=6511

# ============================================
# NODE BEHAVIOR: Join existing network
# ============================================

# Must be "false" for mainnet — joins existing blockchain
# Set "true" only for creating a new local test network
INIT_NODE=false

# Node data directory inside container
ADS_NODE_DIR=/home/ads/.adsd

# ============================================
# DOCKER SETTINGS
# ============================================

COMPOSE_PROJECT_NAME=adshares-mainnet
